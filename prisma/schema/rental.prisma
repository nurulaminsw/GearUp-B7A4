model RentalOrder {
  id          String      @id @default(uuid())
  customerId  String
  providerId  String

  startDate   DateTime
  endDate     DateTime
  status      OrderStatus @default(PLACED)

  subtotal    Decimal
  deposit     Decimal     @default(0)
  totalAmount Decimal

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer User @relation("CustomerOrders", fields: [customerId], references: [id])
  provider User @relation("ProviderOrders", fields: [providerId], references: [id])

  items    RentalOrderItem[]
  payments Payment[]
  review   Review?

  @@index([customerId])
  @@index([providerId])

  @@map("rental_orders")
}

model RentalOrderItem {
  id              String @id @default(uuid())
  rentalOrderId   String
  gearId          String

  quantity        Int
  pricePerDaySnap Decimal
  itemTotal       Decimal

  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id])
  gear        GearItem    @relation(fields: [gearId], references: [id])

  @@index([rentalOrderId])
  @@index([gearId])

  @@map("rental_order_items")
}